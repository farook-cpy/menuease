// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output = "../node_modules/.prisma/client"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

model Restaurant {
    id            String   @unique @default(cuid())
    userId        String
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    name          String
    location      String
    contactNo     String
    isPublished   Boolean
    ownerUsername String?
    ownerPassword String?
    isSuspended   Boolean  @default(false)
    isOwnerDisabled Boolean @default(false)
    menus         Menu[]   @relation("MenusOfRestaurant")
    image         Image?   @relation("ImageOfRestaurant", fields: [imageId], references: [id], onDelete: SetNull, onUpdate: SetNull)
    imageId       String?  @unique
    banners       Image[]  @relation("BannersOfRestaurant")
    planName      String   @default("Free Trial")
    subscriptionStatus String @default("trial")
    subscriptionExpiresAt DateTime?
    trialEndsAt   DateTime?
    balance       Float    @default(0.0)
    currency      String?
    isOrderFeatureEnabled Boolean @default(false)
    whatsappNo    String?
    billingTransactions BillingTransaction[] @relation("BillingTransactionsOfRestaurant")
    analytics     MenuAnalytics[] @relation("AnalyticsOfRestaurant")
    isKitchenEnabled Boolean @default(false)
    orders        Order[]  @relation("OrdersOfRestaurant")
    brandColor    String?
    logoUrl       String?

    @@id([id, userId])
    @@index([isPublished])
}

model Order {
    id           String     @id @default(cuid())
    restaurantId String
    restaurant   Restaurant @relation("OrdersOfRestaurant", fields: [restaurantId], references: [id], onDelete: Cascade)
    table        String?
    floor        String?
    items        String     // JSON-serialized string of items
    status       String     // PENDING, PREPARING, READY, COMPLETED, CANCELLED
    generalNotes String?
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt

    @@index([restaurantId])
    @@index([status])
}

model Menu {
    id            String      @unique @default(cuid())
    userId        String
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt
    name          String
    availableTime String
    position      Int
    categories    Category[]  @relation("CategoriesOfMenu")
    restaurant    Restaurant? @relation("MenusOfRestaurant", fields: [restaurantId], references: [id])
    restaurantId  String?

    @@id([id, userId])
    @@index([restaurantId])
}

model Category {
    id        String     @unique @default(cuid())
    userId    String
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt
    name      String
    position  Int
    items     MenuItem[] @relation("MenuItemsOfCategory")
    menu      Menu?      @relation("CategoriesOfMenu", fields: [menuId], references: [id])
    menuId    String?

    @@id([id, userId])
    @@index([menuId])
}

model MenuItem {
    id          String    @unique @default(cuid())
    userId      String
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    name        String
    description String
    price       String
    position    Int
    category    Category? @relation("MenuItemsOfCategory", fields: [categoryId], references: [id])
    categoryId  String?
    image       Image?    @relation("ImageOfMenuItem", fields: [imageId], references: [id])
    imageId     String?   @unique
    analytics   MenuAnalytics[] @relation("AnalyticsOfMenuItem")
    isVeg       Boolean?
    videoUrl    String?
    images      Image[]   @relation("AdditionalImagesOfMenuItem")
    likes       Int       @default(0)
    dislikes    Int       @default(0)

    @@id([id, userId])
    @@index([categoryId])
}

model Image {
    id                  String      @unique
    path                String
    blurHash            String
    color               String
    menuItem            MenuItem?   @relation("ImageOfMenuItem")
    restaurant          Restaurant? @relation("ImageOfRestaurant")
    restaurantBanner    Restaurant? @relation("BannersOfRestaurant", fields: [restaurantId], references: [id], onDelete: Restrict, onUpdate: Restrict)
    restaurantId        String?
    menuItemAdditional  MenuItem?   @relation("AdditionalImagesOfMenuItem", fields: [menuItemId], references: [id], onDelete: Cascade)
    menuItemId          String?

    @@index([restaurantId])
    @@index([menuItemId])
}

model AdminUser {
    id        String   @id @default(cuid())
    email     String   @unique
    role      String   @default("Admin")
    createdAt DateTime @default(now())
}

model LoginLog {
    id        String   @id @default(cuid())
    username  String
    role      String
    createdAt DateTime @default(now())
}

model BillingTransaction {
    id           String      @id @default(cuid())
    restaurant   Restaurant? @relation("BillingTransactionsOfRestaurant", fields: [restaurantId], references: [id], onDelete: Cascade)
    restaurantId String?
    amount       Float
    type         String // manual_payment, plan_renewal, credit_adjustment, debit_adjustment
    method       String // Cash, Card, Bank Transfer, Credit Balance, System
    description  String
    createdAt    DateTime    @default(now())

    @@index([restaurantId])
}

model MenuAnalytics {
    id           String      @id
    restaurantId String
    restaurant   Restaurant  @relation("AnalyticsOfRestaurant", fields: [restaurantId], references: [id], onDelete: Cascade)
    type         String      // page_view, item_click
    menuItemId   String?
    menuItem     MenuItem?   @relation("AnalyticsOfMenuItem", fields: [menuItemId], references: [id], onDelete: Cascade)
    deviceType   String      @default("Unknown")
    createdAt    DateTime    @default(now())

    @@index([restaurantId])
    @@index([menuItemId])
}
